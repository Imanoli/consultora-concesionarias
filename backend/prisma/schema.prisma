generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Client {
  id              String   @id
  name            String   @db.VarChar(100)
  industry        String   @db.VarChar(50)
  active          Boolean  @default(true)
  metaAdAccountId      String?   @map("meta_ad_account_id") @db.VarChar(30)
  metaLeadActions      Json?     @map("meta_lead_actions")
  metaFondosUsd        Decimal?  @map("meta_fondos_usd") @db.Decimal(10, 2)
  metaFondosUpdatedAt  DateTime? @map("meta_fondos_updated_at")
  metaActiveCampaigns  Int?      @map("meta_active_campaigns")
  googleAdsCustomerId       String?   @map("google_ads_customer_id") @db.VarChar(20)
  googleAdsFondosArs        Decimal?  @map("google_ads_fondos_ars") @db.Decimal(12, 2)
  googleAdsFondosUpdatedAt  DateTime? @map("google_ads_fondos_updated_at")
  googleAdsActiveCampaigns  Int?      @map("google_ads_active_campaigns")
  kommoSubdomain       String?   @map("kommo_subdomain")
  kommoStatusMapping   Json?     @map("kommo_status_mapping")
  createdAt          DateTime  @default(now()) @map("created_at")

  dailyMetrics         DailyMetric[]
  campaignMetricsDaily CampaignMetricDaily[]
  aiInsights           AiInsight[]
  fundLoads            FundLoad[]
  users                User[]
  revenueEntries       RevenueEntry[]
  kommoLeadEvents      KommoLeadEvent[]
  quotes               Quote[]

  @@map("clients")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(100)
  role         String   @default("client") @db.VarChar(10)
  clientId     String?  @map("client_id")
  createdAt    DateTime @default(now()) @map("created_at")

  client       Client?  @relation(fields: [clientId], references: [id])

  @@map("users")
}

model DailyMetric {
  id               Int      @id @default(autoincrement())
  clientId         String   @map("client_id")
  source           String   @db.VarChar(30)
  date             DateTime @db.Date
  spend            Decimal  @default(0) @db.Decimal(10, 2)
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  leads            Int      @default(0)
  reach            Int      @default(0)
  linkClicks       Int      @default(0) @map("link_clicks")
  purchases        Int      @default(0)
  instagramFollows Int      @default(0) @map("instagram_follows")
  frequency        Decimal? @db.Decimal(6, 2)
  cpl              Decimal? @db.Decimal(10, 2)
  ctr              Decimal? @db.Decimal(5, 4)
  cpm              Decimal? @db.Decimal(10, 2)
  cpc              Decimal? @db.Decimal(10, 2)
  conversions      Int      @default(0)
  sessions         Int      @default(0)
  rawData          Json?    @map("raw_data")
  createdAt        DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, source, date])
  @@map("daily_metrics")
}

model CampaignMetricDaily {
  id               Int      @id @default(autoincrement())
  clientId         String   @map("client_id")
  source           String   @db.VarChar(30)
  campaignId       String   @map("campaign_id") @db.VarChar(50)
  campaignName     String   @map("campaign_name") @db.VarChar(200)
  objective        String?  @db.VarChar(60)
  date             DateTime @db.Date
  spend            Decimal  @default(0) @db.Decimal(10, 2)
  impressions      Int      @default(0)
  clicks           Int      @default(0)
  leads            Int      @default(0)
  reach            Int      @default(0)
  linkClicks       Int      @default(0) @map("link_clicks")
  purchases        Int      @default(0)
  instagramFollows Int      @default(0) @map("instagram_follows")
  frequency        Decimal? @db.Decimal(6, 2)
  cpl              Decimal? @db.Decimal(10, 2)
  ctr              Decimal? @db.Decimal(5, 4)
  cpm              Decimal? @db.Decimal(10, 2)
  cpc              Decimal? @db.Decimal(10, 2)
  conversions      Int      @default(0)
  rawData          Json?    @map("raw_data")
  createdAt        DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, source, campaignId, date])
  @@map("campaign_metrics_daily")
}

model FundLoad {
  id        Int      @id @default(autoincrement())
  clientId  String   @map("client_id")
  source    String   @db.VarChar(20)
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @db.VarChar(5)
  loadedAt  DateTime @map("loaded_at") @db.DateTime(0)
  notes     String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  client    Client   @relation(fields: [clientId], references: [id])

  @@map("fund_loads")
}

model RevenueEntry {
  id          Int      @id @default(autoincrement())
  clientId    String   @map("client_id")
  year        Int
  month       Int
  amountArs   Decimal  @map("amount_ars")  @db.Decimal(15, 2)
  usdArsRate  Decimal  @map("usd_ars_rate") @db.Decimal(8, 2)
  notes       String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt        @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, year, month])
  @@map("revenue_entries")
}

model KommoLeadEvent {
  id               Int       @id @default(autoincrement())
  clientId         String    @map("client_id")
  kommoLeadId      String    @map("kommo_lead_id")      @db.VarChar(30)
  kommoStatusId    String    @map("kommo_status_id")    @db.VarChar(30)
  kommoOldStatusId String?   @map("kommo_old_status_id") @db.VarChar(30)
  kommoPipelineId  String?   @map("kommo_pipeline_id")  @db.VarChar(30)
  eventName        String    @map("event_name")         @db.VarChar(60)
  matchKey         String    @map("match_key")          @db.VarChar(20)
  emailHash        String?   @map("email_hash")         @db.VarChar(64)
  phoneHash        String?   @map("phone_hash")         @db.VarChar(64)
  status           String    @default("pending")        @db.VarChar(10)
  metaEventId      String?   @map("meta_event_id")      @db.VarChar(100)
  metaFbtraceId    String?   @map("meta_fbtrace_id")    @db.VarChar(60)
  metaErrorMessage String?   @map("meta_error_message") @db.VarChar(500)
  attempts         Int       @default(0)
  rawWebhook       Json      @map("raw_webhook")
  sentAt           DateTime? @map("sent_at")
  createdAt        DateTime  @default(now())            @map("created_at")
  updatedAt        DateTime  @updatedAt                 @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, kommoLeadId, kommoStatusId])
  @@index([clientId, status])
  @@map("kommo_lead_events")
}

model Quote {
  id                      Int       @id @default(autoincrement())
  clientId                String    @map("client_id")
  publicToken             String    @unique @map("public_token")   @db.VarChar(43)
  status                  String    @default("draft")              @db.VarChar(10)
  kommoLeadId             String?   @map("kommo_lead_id")          @db.VarChar(30)
  kommoNoteStatus         String?   @map("kommo_note_status")      @db.VarChar(10)

  customerName            String    @map("customer_name")          @db.VarChar(150)
  customerPhone           String?   @map("customer_phone")         @db.VarChar(30)
  customerEmail           String?   @map("customer_email")         @db.VarChar(150)
  customerDni             String?   @map("customer_dni")           @db.VarChar(20)

  saleMake                String    @map("sale_make")               @db.VarChar(50)
  saleModel               String    @map("sale_model")              @db.VarChar(80)
  saleVersion             String?   @map("sale_version")            @db.VarChar(80)
  saleYear                Int       @map("sale_year")
  saleKm                  Int?      @map("sale_km")
  salePrice               Decimal   @map("sale_price")              @db.Decimal(12, 2)
  saleCurrency            String    @default("ARS") @map("sale_currency") @db.VarChar(5)

  tradeInMake             String?   @map("trade_in_make")           @db.VarChar(50)
  tradeInModel            String?   @map("trade_in_model")          @db.VarChar(80)
  tradeInYear             Int?      @map("trade_in_year")
  tradeInKm               Int?      @map("trade_in_km")
  tradeInValue            Decimal?  @map("trade_in_value")          @db.Decimal(12, 2)

  paymentMethod           String    @map("payment_method")          @db.VarChar(20)
  financingEntity         String?   @map("financing_entity")        @db.VarChar(80)
  financingDownPayment    Decimal?  @map("financing_down_payment")  @db.Decimal(12, 2)
  financingInstallments   Int?      @map("financing_installments")
  financingInstallmentAmt Decimal?  @map("financing_installment_amount") @db.Decimal(12, 2)
  financingNotes          String?   @map("financing_notes")         @db.VarChar(500)

  totalAmount             Decimal   @map("total_amount")            @db.Decimal(12, 2)

  createdByEmail          String?   @map("created_by_email")        @db.VarChar(150)
  sentAt                  DateTime? @map("sent_at")
  createdAt               DateTime  @default(now())                 @map("created_at")
  updatedAt               DateTime  @updatedAt                      @map("updated_at")

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId, createdAt])
  @@map("quotes")
}

model AiInsight {
  id          Int      @id @default(autoincrement())
  clientId    String   @map("client_id")
  date        DateTime @db.Date
  type        String   @db.VarChar(30)
  severity    String?  @db.VarChar(10)
  title       String   @db.VarChar(200)
  body        String   @db.Text
  rawPrompt   String?  @map("raw_prompt") @db.Text
  rawResponse String?  @map("raw_response") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id])

  @@map("ai_insights")
}
