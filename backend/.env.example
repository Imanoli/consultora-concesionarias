# Base de datos MySQL
DATABASE_URL="mysql://usuario:password@localhost:3306/consultora_db"

# Servidor
PORT=3001
NODE_ENV=development

# Meta Ads
META_ACCESS_TOKEN=
META_APP_SECRET=
META_APP_ID=

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Google Analytics 4
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_KEY_PATH=./secrets/ga4-service-account.json

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# n8n webhook para alertas críticas → WhatsApp
N8N_WEBHOOK_URL=

# CORS — frontend URL permitido
FRONTEND_URL=http://localhost:3000
