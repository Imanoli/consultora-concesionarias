# Base de datos MySQL
DATABASE_URL="mysql://usuario:password@localhost:3306/consultora_db"

# Servidor
PORT=3001
NODE_ENV=development

# Meta Ads
META_ACCESS_TOKEN=
META_APP_SECRET=
META_APP_ID=
META_AD_ACCOUNT_ID=act_
META_GRAPH_API_VERSION=v21.0

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Google Analytics 4
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_KEY_PATH=./secrets/ga4-service-account.json

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# n8n webhook para alertas críticas → WhatsApp
N8N_WEBHOOK_URL=

# Kommo CRM (Dakota) — lectura de leads/contactos + secreto del webhook
KOMMO_SUBDOMAIN_DAKOTA=
KOMMO_API_TOKEN_DAKOTA=
KOMMO_WEBHOOK_SECRET_DAKOTA=

# Meta Conversions API — integración de escritura "Conversion Leads" (Dakota)
# Credenciales separadas a propósito de cualquier token de solo lectura para reporting.
META_PIXEL_ID_DAKOTA=
META_CAPI_ACCESS_TOKEN_DAKOTA=
META_CAPI_APP_SECRET_DAKOTA=
META_CAPI_TEST_EVENT_CODE_DAKOTA=

# CORS — frontend URL permitido
FRONTEND_URL=http://localhost:3000
